generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// —— Auth.js adapter (https://authjs.dev/getting-started/adapters/prisma) ——

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts             Account[]
  sessions             Session[]
  planSnapshots        PlanSnapshot[]
  raceDebriefs         RaceDebrief[]
  customProductList    CustomProductList?
  storedAthleteProfiles StoredAthleteProfile[]
  stravaConnection      StravaConnection?
  prepState             PrepState?
}

/// Jetons OAuth Strava (import d’activités) — distinct du compte Google / e-mail.
model StravaConnection {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  athleteId    String   @map("athlete_id")
  accessToken  String   @map("access_token") @db.Text
  refreshToken String   @map("refresh_token") @db.Text
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("strava_connections")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// —— App data ——

/// Historique / bibliothèque de plans (plusieurs lignes par user). Une ligne peut être marquée active (workspace Race + Plan).
model PlanSnapshot {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  payload   Json
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, isActive])
  @@map("plan_snapshots")
}

model RaceDebrief {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload    Json
  finishedAt DateTime @map("finished_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, finishedAt(sort: Desc)])
  @@map("race_debriefs")
}

model CustomProductList {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("custom_product_lists")
}

/// Profils athlète persistés (plusieurs par utilisateur : ex. été / hiver). `data` = payload AthleteProfile (JSON).
model StoredAthleteProfile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, isDefault])
  @@map("athlete_profiles")
}

/// Etat persistant de la page Pré/Post (checklists, drop bags, protocoles).
model PrepState {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  state     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("prep_states")
}
