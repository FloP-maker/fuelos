generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// —— Auth.js adapter (https://authjs.dev/getting-started/adapters/prisma) ——

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?

  accounts              Account[]
  sessions              Session[]
  planSnapshots         PlanSnapshot[]
  raceDebriefs          RaceDebrief[]
  customProductList     CustomProductList?
  storedAthleteProfiles StoredAthleteProfile[]
  stravaConnection      StravaConnection?
  prepState             PrepState?
  raceEvents            RaceEvent[]
  raceSessions          RaceSession[]
  providerTokens        ProviderToken[]
  cachedActivities      CachedActivity[]
}

/// Jetons OAuth Strava (import d’activités) — distinct du compte Google / e-mail.
model StravaConnection {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  athleteId    String   @map("athlete_id")
  accessToken  String   @map("access_token") @db.Text
  refreshToken String   @map("refresh_token") @db.Text
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("strava_connections")
}

/// Jetons OAuth providers (Strava/Garmin/Wahoo).
model ProviderToken {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider         String
  accessToken      String   @map("access_token") @db.Text
  refreshToken     String?  @map("refresh_token") @db.Text
  oauthTokenSecret String?  @map("oauth_token_secret") @db.Text
  expiresAt        DateTime? @map("expires_at")
  athleteId        String?  @map("athlete_id")
  athleteName      String?  @map("athlete_name")
  scope            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([userId, provider])
  @@index([provider])
  @@map("provider_tokens")
}

/// Cache de détails d'activités provider pour limiter les quotas API.
model CachedActivity {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider           String
  providerActivityId String   @map("provider_activity_id")
  summary            Json
  detail             Json?
  gpxTrack           Json?    @map("gpx_track")
  fetchedAt          DateTime @default(now()) @map("fetched_at")

  @@unique([userId, provider, providerActivityId])
  @@index([userId, provider, fetchedAt])
  @@map("cached_activities")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// —— App data ——

/// Historique / bibliothèque de plans (plusieurs lignes par user). Une ligne peut être marquée active (workspace Race + Plan).
model PlanSnapshot {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  payload   Json
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, isActive])
  @@map("plan_snapshots")
}

model RaceDebrief {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payload    Json
  finishedAt DateTime @map("finished_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, finishedAt(sort: Desc)])
  @@map("race_debriefs")
}

model CustomProductList {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("custom_product_lists")
}

/// Course complétée — mémoire nutritionnelle (payload JSON aligné sur `@/types/race` `RaceEvent`).
model RaceEvent {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Date de la course (tri / filtres).
  raceDate       DateTime @map("race_date")
  /// Score nutritionnel 0–100 (copie pour listes rapides).
  nutritionScore Int      @map("nutrition_score")
  /// Document complet sérialisé (inclut id, dates ISO string, nested objects).
  payload        Json
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  raceSessions   RaceSession[]
  plannedIntakes PlannedIntake[]

  @@index([userId, raceDate(sort: Desc)])
  @@map("race_events")
}

/// Session « mode course » temps réel (sync optionnelle cloud).
model RaceSession {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  raceEventId String?           @map("race_event_id")
  raceEvent   RaceEvent?        @relation(fields: [raceEventId], references: [id], onDelete: SetNull)
  startedAt   DateTime          @map("started_at")
  status      RaceSessionStatus
  currentKm   Float             @default(0) @map("current_km")
  currentMin  Int               @default(0) @map("current_min")
  liveStats   Json              @map("live_stats")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  plannedIntakes PlannedIntake[]
  intakeActions  IntakeAction[]

  @@index([userId])
  @@index([raceEventId])
  @@map("race_sessions")
}

enum RaceSessionStatus {
  active
  paused
  finished
}

/// Prises planifiées suivies en live (une ligne par prise).
model PlannedIntake {
  id             String              @id @default(cuid())
  raceSessionId  String              @map("race_session_id")
  raceSession    RaceSession         @relation(fields: [raceSessionId], references: [id], onDelete: Cascade)
  raceEventId    String?             @map("race_event_id")
  raceEvent      RaceEvent?          @relation(fields: [raceEventId], references: [id], onDelete: SetNull)
  sortIndex      Int                 @default(0) @map("sort_index")
  scheduledAtMin Int                 @map("scheduled_at_min")
  scheduledAtKm  Float               @map("scheduled_at_km")
  product        Json
  choG           Float               @map("cho_g")
  sodiumMg       Float               @map("sodium_mg")
  fluidMl        Float               @map("fluid_ml")
  intakeType     String              @map("intake_type")
  status         PlannedIntakeStatus @default(pending)
  actualIntake   Json?               @map("actual_intake")

  intakeActions IntakeAction[]

  @@index([raceSessionId])
  @@index([raceEventId])
  @@map("planned_intakes")
}

enum PlannedIntakeStatus {
  pending
  taken
  skipped
  modified
  vomited
  delayed
}

/// File d’actions offline / avant sync (debounced côté client).
model IntakeAction {
  id              String         @id @default(cuid())
  raceSessionId   String         @map("race_session_id")
  raceSession     RaceSession    @relation(fields: [raceSessionId], references: [id], onDelete: Cascade)
  plannedIntakeId String?        @map("planned_intake_id")
  plannedIntake   PlannedIntake? @relation(fields: [plannedIntakeId], references: [id], onDelete: SetNull)
  action          String         @map("action")
  actualIntake    Json?          @map("actual_intake")
  clientTimestamp DateTime       @map("client_timestamp")
  synced          Boolean        @default(false)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([raceSessionId, synced])
  @@map("intake_actions")
}

/// Profils athlète persistés (plusieurs par utilisateur : ex. été / hiver). `data` = payload AthleteProfile (JSON).
model StoredAthleteProfile {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([userId, isDefault])
  @@map("athlete_profiles")
}

/// Etat persistant de la page Pré/Post (checklists, drop bags, protocoles).
model PrepState {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  state     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("prep_states")
}
